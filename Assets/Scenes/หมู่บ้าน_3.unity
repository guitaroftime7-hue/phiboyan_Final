  npcName: "\u0E1E\u0E48\u0E2D (\u0E1C\u0E39\u0E49\u0E43\u0E2B\u0E0D\u0E48\u0E1A\u0E49\u0E32\u0E19)"
  lines:
  - "\u0E40\u0E1B\u0E47\u0E19\u0E22\u0E31\u0E07\u0E44\u0E07\u0E1A\u0E49\u0E32\u0E07\u0E25\u0E39\u0E01
    \u0E2A\u0E1A\u0E32\u0E22\u0E14\u0E35\u0E43\u0E0A\u0E48\u0E21\u0E31\u0E49\u0E22"
  - "\u0E14\u0E35\u0E40\u0E40\u0E25\u0E49\u0E27\u0E17\u0E35\u0E48\u0E21\u0E32\u0E0A\u0E48\u0E27\u0E22
    \u0E2B\u0E21\u0E39\u0E48\u0E1A\u0E49\u0E32\u0E19\u0E19\u0E35\u0E49 \u0E1E\u0E48\u0E2D\u0E04\u0E19\u0E40\u0E14\u0E35\u0E22\u0E27\u0E44\u0E21\u0E48\u0E44\u0E2B\u0E27\u0E01\u0E31\u0E1A\u0E1C\u0E35\u0E23\u0E49\u0E32\u0E22\u0E41\u0E19\u0E48\u0E46"
  - "\u0E15\u0E2D\u0E19\u0E01\u0E25\u0E32\u0E07\u0E04\u0E37\u0E19\u0E40\u0E27\u0E25\u0E32\u0E19\u0E2D\u0E19
    \u0E21\u0E31\u0E19\u0E0A\u0E2D\u0E1A\u0E44\u0E1B\u0E2D\u0E33 \u0E1E\u0E27\u0E01\u0E0A\u0E32\u0E27\u0E1A\u0E49\u0E32\u0E19\u0E19\u0E2D\u0E19\u0E01\u0E31\u0E19\u0E44\u0E21\u0E48\u0E44\u0E14\u0E49\u0E40\u0E25\u0E22\n"
  - "\u0E44\u0E1B\u0E46 \u0E40\u0E02\u0E49\u0E32\u0E44\u0E1B\u0E43\u0E19\u0E1A\u0E49\u0E32\u0E19\u0E1E\u0E31\u0E01\u0E1C\u0E48\u0E2D\u0E19\u0E01\u0E48\u0E2D\u0E19\n"
